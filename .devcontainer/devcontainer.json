{
    "name": "Vala Adwaita",
    "build": {
        "dockerfile": "./Dockerfile"
    },
    "postCreateCommand": "sudo apk update && sudo apk add alpine-sdk meson ninja gtk4.0-dev libadwaita-dev desktop-file-utils gobject-introspection-dev adwaita-icon-theme font-dejavu json-glib-dev libgee-dev uncrustify gdb vala vala-language-server",
    "postAttachCommand": "meson setup _build",
    // "containerEnv": {},
    "customizations": {
        "vscode": {
            "extensions": [
                // "vadimcn.vscode-lldb",
                "ms-vscode.cpptools",
                "mesonbuild.mesonbuild",
                "Gruntfuggly.todo-tree",
                "zachflower.uncrustify",
                "prince781.vala",
                "redhat.vscode-xml",
                "EditorConfig.EditorConfig",
                "nefrob.vscode-just-syntax"
                // "vscodevim.vim"
            ],
            "settings": {
                "mesonbuild.configureOnOpen": false
            }
        }
    },
    "remoteUser": "adw"
}
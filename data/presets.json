{
    "formats": {
        "mp3": {
            "name": "MPEG / mp3",
            "extension": "mp3",
            "encoder": "lamemp3enc",
            "bitrateMult": 1,
            "filters": [
                "mpegaudioparse",
                "xingmux",
                "id3v2mux"
            ]
        },
        "m4a": {
            "name": "AAC / m4a",
            "extension": "m4a",
            "encoder": "avenc_aac",
            "bitrateMult": 1000,
            "filters": [
                "mp4mux"
            ]
        },
        "oogg": {
            "name": "Opus / ogg",
            "extension": "ogg",
            "encoder": "avenc_aac",
            "bitrateMult": 1000,
            "filters": [
                "opusenc"
            ]
        }
    },
    "quality_presets": {
        "high": {
            "name": "High Quality",
            "format": "m4a",
            "bitrate": 192,
            "samplerate": 48000
        },
        "standard": {
            "name": "Standard Quality",
            "format": "m4a",
            "bitrate": 128,
            "samplerate": 44100
        },
        "libre": {
            "name": "Libre (Standard w/Opus)",
            "format": "oogg",
            "bitrate": 128,
            "samplerate": 44100
        },
        "compatibility": {
            "name": "Compatibility",
            "format": "mp3",
            "bitrate": 128,
            "samplerate": 44100
        }
    }
}
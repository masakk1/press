<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template>
    <property name="title" translatable="yes">Press</property>
    <property name="tag">config_page</property>
    <child>
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
          </object>
        </child>
        <property name="content">
          <object class="AdwPreferencesPage">
            <child>
              <object class="AdwPreferencesGroup">
                <property name="title" translatable="yes">Configure</property>
                <child>
                  <object class="AdwActionRow" id="source_directory_row">
                    <property name="title" translatable="yes">Source Directory</property>
                    <property name="subtitle" translatable="yes">/path/to/directory</property>
                    <property name="activatable-widget">source_directory_button</property>
                    <style>
                      <class name="property" />
                    </style>
                    <child type="suffix">
                      <object class="GtkButton" id="source_directory_button">
                        <property name="icon-name">folder-open-symbolic</property>
                        <property name="valign">3</property>
                        <style>
                          <class name="flat" />
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow" id="target_directory_row">
                    <property name="title" translatable="yes">Target Directory</property>
                    <property name="subtitle" translatable="yes">/path/to/directory</property>
                    <property name="activatable-widget">target_directory_button</property>
                    <style>
                      <class name="property" />
                    </style>
                    <child type="suffix">
                      <object class="GtkButton" id="target_directory_button">
                        <property name="icon-name">folder-open-symbolic</property>
                        <property name="valign">3</property>
                        <style>
                          <class name="flat" />
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwComboRow" id="quality_preset_selection">
                    <property name="title" translatable="yes">Quality Preset</property>
                    <signal name="activated" handle="on_quality_preset_selected" swapped="no"></signal>
                  </object>
                </child>
                <child>
                  <object class="AdwSwitchRow" id="replace_destination_files_switch">
                    <property name="title" translatable="yes">Replace files on destination</property>
                  </object>
                </child>
                <child>
                  <object class="AdwSwitchRow" id="copy_noaudio_files_switch">
                    <property name="title" translatable="yes">Copy non-audio files on destination</property>
                    <property name="active">true</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="AdwPreferencesGroup" id="custom_quality_group">
                <property name="title" translatable="yes">Custom Target Quality</property>
                <property
                  name="description"
                  translatable="yes">Manually configure the maximum target quality.</property>
                <property name="visible">false</property>
                <child>
                  <object class="AdwComboRow" id="custom_quality_format">
                    <property name="title" translatable="yes">Encoder / Format</property>
                  </object>
                </child>
                <child>
                  <object class="AdwSpinRow" id="custom_quality_bitrate">
                    <property name="title" translatable="yes">Bitrate (Kbps)</property>
                    <property name="adjustment">
                      <object class="GtkAdjustment">
                        <property name="lower">64</property>
                        <property name="upper">320</property>
                        <property name="value">128</property>
                        <property name="page-increment">32</property>
                        <property name="step-increment">16</property>
                      </object>
                    </property>
                  </object>
                </child>
                <child>
                  <object class="AdwSpinRow" id="custom_quality_samplerate">
                    <property name="title" translatable="yes">Sample Rate (Hz)</property>
                    <property name="adjustment">
                      <object class="GtkAdjustment">
                        <property name="lower">8000</property>
                        <property name="upper">96000</property>
                        <property name="value">44100</property>
                        <property name="page-increment">4000</property>
                        <property name="step-increment">1000</property>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="AdwPreferencesGroup">
                <child>
                  <object class="GtkButton" id="compress_button">
                    <property name="label" translatable="yes">Compress</property>
                    <style>
                      <class name="pill" />
                      <class name="suggested-action" />
                    </style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </property>
      </object>
    </child>
  </template>
</interface>

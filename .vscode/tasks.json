{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "meson-setup",
            "type": "shell",
            "command": "meson setup _build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "meson-compile",
            "type": "shell",
            "command": "meson compile -C _build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        }
    ]
}

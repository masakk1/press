  <!-- <url type="donation">https://example.org/donate</url> -->
  <url type="contact">https://github.com/masakk1</url>
  <!-- <url type="contribute">https://example.org/contribute</url> -->

  <translation type="gettext">press</translation>
  <launchable type="desktop-id">io.github.masakk1.press.desktop</launchable>
  <!-- (https://hughsie.github.io/oars/generate.html) - use oars-1.1 -->
  <content_rating type="oars-1.1" />

  <branding>
    <color type="primary" scheme_preference="light">#2ec27e</color>
    <color type="primary" scheme_preference="dark">#57e389</color>
  </branding>

